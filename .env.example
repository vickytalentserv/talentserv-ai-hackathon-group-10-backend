# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://api.realestate-hackathon
AUTH0_ALGORITHMS=RS256

# Database (Railway MySQL example)
DATABASE_URL=mysql+pymysql://user:password@host:3306/railway

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# App
APP_ENV=development
INGEST_API_KEY=local-dev-ingest-key
DATA_DIR=data
# Optional LLM enhancement for requirement parsing
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
